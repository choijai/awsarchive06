# Firebase Configuration
# https://console.firebase.google.com 에서 프로젝트 설정 → 앱 추가 → 웹
# 아래 값들을 .env 파일에 복사해서 채워넣으세요

VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ✅ Claude API Key (서버에만 저장)
# 절대 프론트엔드에 노출하지 마세요!
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ✅ Gemini API Key (서버에만 저장)
# 절대 프론트엔드에 노출하지 마세요!
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Admin Configuration (보안: 환경변수로만 관리)
VITE_ADMIN_EMAILS=admin@example.com
VITE_TEST_PAID_EMAILS=testuser@example.com

# Contact Form Email (환경변수로만 관리, 로직에 노출 금지)
CONTACT_EMAIL=your-email@gmail.com

# Resend Email API (https://resend.com 에서 발급)
RESEND_API_KEY=your_resend_api_key_here
